{
  "name": "rating-gate",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "data:audit": "node scripts/audit-bangumi-pools.mjs",
    "data:seed": "node scripts/fetch-bangumi-seed.mjs",
    "dev": "vite",
    "dev:ws": "node scripts/ws-room-server.mjs",
    "build": "tsc && vite build",
    "test:smoke": "node scripts/smoke-test.mjs",
    "test:multiplayer": "node scripts/multiplayer-smoke-test.mjs",
    "worker:deploy": "npm --prefix worker run deploy",
    "worker:deploy:ci": "npm --prefix worker ci && npm --prefix worker run deploy",
    "worker:dev": "npm --prefix worker run dev",
    "worker:typecheck": "npm --prefix worker run typecheck",
    "preview": "vite preview"
  },
  "devDependencies": {
    "playwright-core": "^1.60.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "ws": "^8.20.1"
  }
}
